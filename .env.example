# Configuration for the production VPS deployment.
# Copy to `.env` and edit, then run:
#   docker compose -f docker-compose.prod.yml up -d --build

# ---------------------------------------------------------------------------
# Public address served by Caddy.
#
#  - A domain (recommended): Caddy fetches a Let's Encrypt cert automatically.
#        SITE_ADDRESS=crypttraject.example.com
#  - No domain yet: serve plain HTTP on the VPS IP (no TLS).
#        SITE_ADDRESS=:80
# ---------------------------------------------------------------------------
SITE_ADDRESS=:80

# Email used for Let's Encrypt registration. Required only when SITE_ADDRESS
# is a real domain; leave empty for the :80 / HTTP-only mode.
ACME_EMAIL=

# ---------------------------------------------------------------------------
# CORS for the FastAPI server. Only needed if the browser landing page must
# call the API cross-origin. The desktop CLI/GUI does NOT need this.
#   - empty  : no CORS headers (default)
#   - "*"    : allow any origin
#   - list   : https://crypttraject.example.com,https://www.example.com
# When the web page and API share the same domain (served via /api by Caddy),
# this can stay empty.
# ---------------------------------------------------------------------------
CRYPTTRAJECT_CORS_ORIGINS=
